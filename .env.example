# Server
PORT=3000
NODE_ENV=development
TRACKING_ENABLED=false

# PostgreSQL
DATABASE_URL=postgresql://<db_user>:<db_password>@localhost:5432/<db_name>

# Redis
REDIS_URL=redis://localhost:6379

# Facebook
FB_APP_ID=your_facebook_app_id
FB_APP_SECRET=your_facebook_app_secret
FB_VERIFY_TOKEN=your_random_verify_token
# OAuth scope list (comma separated). Keep minimal for broader user compatibility.
FB_OAUTH_SCOPES=public_profile,pages_show_list,pages_read_engagement,pages_manage_metadata
FB_OAUTH_CONFIG_ID=
FB_OAUTH_REDIRECT_URI=http://localhost:3000/api/integrations/facebook/oauth/callback
# Optional helper for local setup scripts (not required by runtime)
FB_PAGE_ACCESS_TOKEN=your_facebook_page_access_token

# Google OAuth (Sheets)
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/integrations/google/oauth/callback

# Security
# 64 hex chars (32 bytes), example generated securely
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
JWT_SECRET=replace_with_strong_random_jwt_secret
JWT_EXPIRES_IN=7h
JWT_REFRESH_EXPIRES_IN=7d

# Telegram (optional notifications)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Bitrix24 (stored per-integration in DB, not env)
# Example format only:
# https://<domain>.bitrix24.<tld>/rest/<user>/<token>/

# ngrok (dev only)
NGROK_AUTHTOKEN=your_ngrok_authtoken

